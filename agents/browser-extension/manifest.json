{
  "manifest_version": 3,
  "name": "Ultron Capture",
  "version": "0.1.0",
  "description": "Capture the current page into Ultron's knowledge (skill intake), and run quick commands.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://localhost:8080/*", "http://localhost:8081/*"],
  "background": { "service_worker": "background.js", "type": "module" },
  "action": { "default_popup": "popup.html", "default_title": "Ultron Capture" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
