# ===========================================================================
# Ultron-OS environment — ALL defaults are free + local. Zero paid keys.
# Copy to `.env` and adjust. NEVER commit your real .env.
# ===========================================================================

# --- Database (Postgres 16 + pgvector) ---
POSTGRES_DB=ultron
POSTGRES_USER=ultron
POSTGRES_PASSWORD=ultron
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080

# --- Governance (Section 14 — hardcoded safe default) ---
# Human-in-the-loop. CRITICAL/HIGH actions are gated. Do NOT set true casually.
ULTRON_AUTO_APPROVE=false

# --- Brain (model-agnostic; local-first) ---
# Default brain is the offline HeuristicBrain. If an Ollama server is reachable
# at this URL, OllamaBrain is used automatically; otherwise it falls back.
ULTRON_BRAIN_OLLAMA_BASE_URL=http://localhost:11434
ULTRON_BRAIN_OLLAMA_MODEL=llama3.1
ULTRON_BRAIN_OLLAMA_ENABLED=true
# Dedicated embedding model (chat models like llama3.1 cannot embed). Pull it once with:
#   ollama pull nomic-embed-text
ULTRON_BRAIN_OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_PORT=11434
# Reasoning tuning (no secrets). Persona/system prompt, sampling temperature, how long
# Ollama keeps the model resident, and how long the availability probe is cached (ms).
# ULTRON_BRAIN_SYSTEM_PROMPT="You are Ultron, a local-first personal AI..."
ULTRON_BRAIN_TEMPERATURE=0.2
ULTRON_BRAIN_KEEP_ALIVE=5m
ULTRON_BRAIN_AVAILABILITY_CACHE_MILLIS=5000

# --- GitHub connector ---
# Phase 0 uses the bundled fixture (no network). Leave token empty to stay offline.
# When set, the REST connector can be enabled in later phases.
ULTRON_GITHUB_MODE=fixture
# GITHUB_TOKEN=        # opt-in only; keep blank for fully offline operation

# --- Cloud LLM upgrades (ALL opt-in, blank by default; preferred over Ollama when set) ---
# OpenAI: set the key to route reasoning through gpt-4o-mini (or change the model).
# OPENAI_API_KEY=sk-...
# ULTRON_BRAIN_OPENAI_MODEL=gpt-4o-mini
# Google Gemini: set the key to use gemini-1.5-flash.
# GOOGLE_API_KEY=AIza...
# ULTRON_BRAIN_GEMINI_MODEL=gemini-1.5-flash
# ANTHROPIC_API_KEY=          # Claude 3 Haiku (console.anthropic.com → API keys)
# GROQ_API_KEY=               # fastest free inference (console.groq.com/keys)
# OPENROUTER_API_KEY=         # routes to $0 models (openrouter.ai/keys)
# NVIDIA_API_KEY=             # NIM free dev tier incl. deepseek-r1 (build.nvidia.com)
# GitHub Models (gpt-4o, free for devs) reuses GITHUB_TOKEN below — no extra key needed.
# Provider priority: OpenAI → Anthropic → Gemini → Groq → GitHub → OpenRouter → NVIDIA → Ollama → Heuristic.

# --- Security: optional API-key gate for /api/** (browser extension / remote web apps) ---
# Blank = open (local dev). Set a value and send header  X-Ultron-Key: <value>  from clients.
# ULTRON_API_KEY=

# --- App connectors (opt-in; sends/creates are approval-gated; Twilio stays disabled) ---
# ULTRON_CONNECTORS_GMAILTOKEN=
# ULTRON_CONNECTORS_CALENDARTOKEN=
# ULTRON_CONNECTORS_NOTIONTOKEN=
# ULTRON_CONNECTORS_SLACKTOKEN=
# ULTRON_CONNECTORS_SPOTIFYTOKEN=
# ULTRON_CONNECTORS_HOMEASSISTANTURL=
# ULTRON_CONNECTORS_HOMEASSISTANTTOKEN=
# Contact extension point — leave OFF unless you deliberately wire it:
# ULTRON_CONNECTORS_TWILIOACCOUNTSID=
# ULTRON_CONNECTORS_TWILIOAUTHTOKEN=
# ULTRON_CONNECTORS_TWILIOLIVEENABLED=false

# --- Python ai-layer bridge (rich skill intake / better embeddings) ---
# ULTRON_PYTHON_BRIDGE_ENABLED=false
# ULTRON_PYTHON_BRIDGE_URL=http://localhost:8000
# ULTRON_PYTHON_BRIDGE_KEY=
