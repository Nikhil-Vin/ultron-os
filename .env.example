# ===========================================================================
# Ultron-OS environment — ALL defaults are free + local. Zero paid keys.
# Copy to `.env` and adjust. NEVER commit your real .env.
# ===========================================================================

# --- Database (Postgres 16 + pgvector) ---
POSTGRES_DB=ultron
POSTGRES_USER=ultron
POSTGRES_PASSWORD=ultron
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8080

# --- Governance (Section 14 — hardcoded safe default) ---
# Human-in-the-loop. CRITICAL/HIGH actions are gated. Do NOT set true casually.
ULTRON_AUTO_APPROVE=false

# --- Brain (model-agnostic; local-first) ---
# Default brain is the offline HeuristicBrain. If an Ollama server is reachable
# at this URL, OllamaBrain is used automatically; otherwise it falls back.
ULTRON_BRAIN_OLLAMA_BASE_URL=http://localhost:11434
ULTRON_BRAIN_OLLAMA_MODEL=llama3.1
OLLAMA_PORT=11434

# --- GitHub connector ---
# Phase 0 uses the bundled fixture (no network). Leave token empty to stay offline.
# When set, the REST connector can be enabled in later phases.
ULTRON_GITHUB_MODE=fixture
# GITHUB_TOKEN=        # opt-in only; keep blank for fully offline operation

# --- Cloud LLM upgrades (ALL opt-in, blank by default) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
